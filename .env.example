# NETRUN OS — client environment (Phase 0)
# Copy this file to `.env` and fill in the values from your Supabase project.
# Supabase Dashboard -> your project -> Settings -> API
#
# SECURITY: The client build uses ONLY the anon (public) key + Row-Level Security.
# The service_role key is NEVER placed here or bundled in any client build.
# It lives only as an Edge Function secret in Supabase.

# Project URL, e.g. https://abcdefghijklmno.supabase.co
VITE_SUPABASE_URL=

# anon / public key (safe to ship in a client; RLS enforces access)
VITE_SUPABASE_ANON_KEY=
